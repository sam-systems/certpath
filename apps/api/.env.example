# Copia a .env y rellena. NO subir .env al repo.
# SQLite (dev local):
DATABASE_URL="file:./dev.db"
# Postgres (prod) — cambia también provider a "postgresql" en prisma/schema.prisma:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

PORT=4000

# Token para importar certificaciones/libros/recursos (cabecera x-import-token)
IMPORT_TOKEN="cambia-esto"

# Tag de Amazon Afiliados (ej: "tunombre-21"); se añade a los enlaces de compra por ISBN
AMAZON_AFFILIATE_TAG=""

# Credenciales del único usuario admin (login)
ADMIN_EMAIL="admin@certpath.local"
# Hash bcrypt de la contraseña (genera con scripts/gen-auth-env.mjs)
ADMIN_PASSWORD_HASH=""
# Secreto para firmar el JWT (hex aleatorio)
AUTH_SECRET=""
